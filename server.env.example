# ShadowHunters default environment template
# Copy this file to server.env and adjust values for your machine.

# Server bind settings
HOST=0.0.0.0
PORT=5600

# 1=true: auto create a test room on startup, 0=false
BOOTSTRAP_TEST_ROOM=1

# SQLite DB path
DB_PATH=backend/data/shadowhunters.db

# Optional: Cloudflare tunnel token (leave empty if unused)
CF_TUNNEL_TOKEN=
